generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Produto {
  id        Int      @id @default(autoincrement())
  nome      String
  descricao String
  preco     Float
  imagem    String
  modelo3d  String
  categoria String   @default("Geral")
  createdAt DateTime @default(now())
}

model Usuario {
  id        Int      @id @default(autoincrement())
  nome      String
  email     String   @unique
  senha     String
  tipo      String   @default("cliente")
  pedidos   Pedido[]
  createdAt DateTime @default(now())
}

model Pedido {
  id        Int      @id @default(autoincrement())
  usuarioId Int
  usuario   Usuario  @relation(fields: [usuarioId], references: [id])
  produtos  String   @db.Text
  total     Float
  status    String   @default("pendente")
  createdAt DateTime @default(now())
}